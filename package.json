{
  "name": "world-cup-scheduler",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run brand:assets && tsc -b && vite build && node scripts/generate-seo-assets.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "brand:assets": "node scripts/generate-brand-assets.mjs",
    "images": "node scripts/optimize-images.mjs",
    "preview": "vite preview",
    "cloudflare:deploy": "npm run build && wrangler deploy",
    "cloudflare:dry-run": "npm run build && wrangler deploy --dry-run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "sharp": "^0.35.1",
    "tailwindcss": "^4.3.0",
    "text-to-svg": "^3.1.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0"
  }
}
