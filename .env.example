VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
VITE_ADSENSE_CLIENT=ca-pub-1076235663167007
# VAPID public key for browser push. NOT secret — it ships to the browser as the
# applicationServerKey. Must match the VAPID_PUBLIC_KEY edge-function secret below.
VITE_VAPID_PUBLIC_KEY=

# Optional static affiliate fallbacks. Prefer DB rows in watch_providers/watch_links for new approvals.
# Values may be either a full tracking URL or a short partner/sub id.
VITE_AFFILIATE_DAZN=
VITE_AFFILIATE_ESPN_PLUS=
VITE_AFFILIATE_PARAMOUNT_PLUS=
VITE_AFFILIATE_SLING=
VITE_AFFILIATE_FUBO=
VITE_AFFILIATE_UFC_FIGHT_PASS=

# Server-only Supabase Edge Function secrets. Never expose these with VITE_.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
THESPORTSDB_API_KEY=...
APISPORTS_KEY=...
RESEND_API_KEY=re_...
# Alias supported for the existing Supabase dashboard secret name.
RESENDAPI=re_...
EMAIL_FROM=Silbo Sports <reminders@silbosports.com>
APP_URL=https://silbosports.com
# Web Push (VAPID). Public key is the same value as VITE_VAPID_PUBLIC_KEY above.
# Private key is a real secret — set it only in Supabase, never commit it.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:alerts@silbosports.com
